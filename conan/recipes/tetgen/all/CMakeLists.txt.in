cmake_minimum_required(VERSION 3.15)
project(tetgen LANGUAGES CXX C)

add_library(tetgen STATIC tetgen.h tetgen.cxx predicates.cxx)

option(TETGEN_USE_CGAL_PREDICATES "Use CGAL exact predicates" OFF)
if(TETGEN_USE_CGAL_PREDICATES)
  find_package(CGAL REQUIRED)
  target_compile_definitions(tetgen PRIVATE USE_CGAL_PREDICATES)
  target_link_libraries(tetgen PUBLIC CGAL::CGAL)
endif()

target_compile_definitions(tetgen PUBLIC TETLIBRARY)
target_include_directories(tetgen PUBLIC
  $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}>
  $<INSTALL_INTERFACE:include>
)

include(GNUInstallDirs)

install(TARGETS tetgen
  ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR}
  LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
  RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}
)
install(FILES tetgen.h DESTINATION ${CMAKE_INSTALL_INCLUDEDIR})
