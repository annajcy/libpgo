cmake_minimum_required(VERSION 3.15)
project(CCD_SafeCCD LANGUAGES CXX)

add_library(CCD_SafeCCD STATIC
  safeCCDWrapper.cpp
)

target_include_directories(CCD_SafeCCD PUBLIC
  $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}>
  $<INSTALL_INTERFACE:include/SafeCCD>
)

set_target_properties(CCD_SafeCCD PROPERTIES
  CXX_STANDARD 17
  CXX_STANDARD_REQUIRED ON
  POSITION_INDEPENDENT_CODE ON
)

include(GNUInstallDirs)

install(TARGETS CCD_SafeCCD
  ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR}
  LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
  RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}
)
install(FILES
  SAFE_CCD.h MY_MATH.h safeCCDWrapper.h
  DESTINATION ${CMAKE_INSTALL_INCLUDEDIR}/SafeCCD
)
